# ========================================
# TURSO DATABASE CONFIGURATION
# ========================================
# URL do banco de dados Turso (obtido com: turso db create)
TURSO_DB_URL=libsql://your-db-name.turso.io

# Token de autenticação do Turso (obtido com: turso db tokens create --readwrite)
# Este token dá acesso completo ao banco (read/write)
TURSO_DB_AUTH_TOKEN=eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# CLOUDFLARE CONFIGURATION
# ========================================
# Zone ID do domínio kill-kick.shop (Dashboard → Overview → sidebar direita)
CLOUDFLARE_ZONE_ID=abcdef123456...

# API Token da Cloudflare com permissão "Edit Zone DNS"
# Criado em: Dashboard → Profile → API Tokens → Create Token → Edit Zone DNS
# Formato: Bearer abc123...
CLOUDFLARE_API_TOKEN=Bearer abc123...

# ID do registro DNS CNAME para controller.kill-kick.shop
# Obtido via API ou DevTools (ver docs/setup/cloudflare-setup.md)
DNS_RECORD_ID=1234567890abcdef

# ========================================
# TUNNEL GALIO CONFIGURATION
# ========================================
# ID/Hostname do tunnel Galio (formato: uuid.cfargotunnel.com)
# Obtido com: cloudflared tunnel create galio
GALIO_TUNNEL_ID=uuid-galio.cfargotunnel.com

# Token do tunnel Galio (obtido com: cloudflared tunnel token galio)
# Este token é usado para iniciar o tunnel sem autenticação interativa
GALIO_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# TUNNEL BORIO CONFIGURATION
# ========================================
# ID/Hostname do tunnel Borio (formato: uuid.cfargotunnel.com)
# Obtido com: cloudflared tunnel create borio
BORIO_TUNNEL_ID=uuid-borio.cfargotunnel.com

# Token do tunnel Borio (obtido com: cloudflared tunnel token borio)
# Este token é usado para iniciar o tunnel sem autenticação interativa
BORIO_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# DOMAIN CONFIGURATION
# ========================================
# Domínio alvo que aponta para os tunnels
TARGET_DOMAIN=controller.kill-kick.shop

# ========================================
# ROTATION CONFIGURATION
# ========================================
# Intervalo base para rotação em minutos (340 minutos = 5h40m)
# Este é o tempo mínimo entre rotações
ROTATION_INTERVAL_MINUTES=340

# Jitter aleatório em minutos (0-10 minutos adicionais)
# Adiciona aleatoriedade para evitar detecção de padrões
ROTATION_JITTER_MINUTES=10

# Máximo de tentativas de health check (15 tentativas)
# Cada tentativa tem um intervalo definido abaixo
HEALTH_CHECK_RETRIES=15

# Intervalo entre health checks em segundos (10 segundos)
# Tempo total de espera: 15 * 10 = 150s = 2.5 minutos
HEALTH_CHECK_INTERVAL_SECONDS=10

# ========================================
# GEMINI AI (Opcional - Fase 2)
# ========================================
# Chaves de API da Gemini para gerar nomes de repositórios/workflows
# Separe múltiplas chaves com vírgula
# Obtido em: https://makersuite.google.com/app/apikey
GEMINI_API_KEYS=key1,key2,key3

# ========================================
# SECURITY
# ========================================
# Usuário para autenticação na UI (Fase 2)
BASIC_AUTH_USER=admin

# Senha (Chave de Acesso) para autenticação na UI
# Use uma senha forte (mínimo 16 caracteres)
# Esta senha é usada para login no painel de controle
BASIC_AUTH_PASS=your-secure-password-here

# ========================================
# NOTES
# ========================================
# 1. NÃO comite este arquivo no Git (já está no .gitignore)
# 2. Crie um arquivo .env.local para desenvolvimento
# 3. Valores com ... são placeholders e devem ser substituídos
# 4. Tokens expiram - rotacione periodicamente
# 5. Mantenha este arquivo seguro - contém credenciais sensíveis
